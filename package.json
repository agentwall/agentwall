{
  "name": "@agentwall/agentwall",
  "version": "0.8.1",
  "description": "Run AI agents safely on your local machine — policy-enforcing MCP proxy",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "agentwall": "dist/cli.js"
  },
  "files": [
    "dist/",
    "index.js",
    "src/hook.js",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "ai",
    "agents",
    "safety",
    "claude",
    "cursor",
    "openclaw",
    "agentwall",
    "proxy",
    "policy"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agentwall/agentwall.git"
  },
  "homepage": "https://github.com/agentwall/agentwall#readme",
  "bugs": {
    "url": "https://github.com/agentwall/agentwall/issues"
  },
  "openclaw": {
    "extensions": [
      "./index.js"
    ]
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "js-yaml": "^4.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.12",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
