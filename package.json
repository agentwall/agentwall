{
  "name": "agentwall",
  "version": "0.3.0",
  "description": "Runtime safety layer for local AI agents — MCP proxy + OpenClaw plugin",
  "type": "module",
  "main": "index.js",
  "bin": {
    "agentwall": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "agents",
    "safety",
    "openclaw",
    "llm",
    "security"
  ],
  "license": "MIT",
  "openclaw": {
    "extensions": [
      "./index.js"
    ]
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "js-yaml": "^4.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.12",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
